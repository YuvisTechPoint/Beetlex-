{
  "name": "beetlex-hackathon",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:qa": "cross-env VITE_ENABLE_MSW=true VITE_QA_FAST_MS=true tsc -b && vite build",
    "lint": "eslint src e2e playwright.config.ts",
    "preview": "vite preview",
    "preview:qa": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "qa:screenshots": "playwright test e2e/screenshots.spec.ts",
    "qa:lighthouse": "node scripts/run-lighthouse.mjs",
    "qa:report": "node scripts/generate-quality-report.mjs",
    "qa": "node scripts/qa-pipeline.mjs",
    "postinstall": "playwright install chromium"
  },
